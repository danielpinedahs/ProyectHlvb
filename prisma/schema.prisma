generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model CLIENTS {
  ID_CLIENT   BigInt   @id @default(autoincrement())
  PS_SURNAME  String?
  PS_GIVNAM   String?
  PS_SEX      String?
  PS_EMAIL    String?
  PS_DBIRTH   DateTime? @db.Date
  PS_COUNTRY  String?

  APPLICATION APPLICATION[]
}

model APPLICATION {
  ID_APPLICATION BigInt   @id @default(autoincrement())
  ID_CLIENT      BigInt

  APP_NAME       String?
  APP_STATUS     String?
  APP_CREATED    DateTime @default(now())
  APP_UPDATED    DateTime @updatedAt
  APP_SUBMITTED  DateTime?

  CLIENT CLIENTS @relation(fields: [ID_CLIENT], references: [ID_CLIENT])

  CLIENT_INFO CLIENT_INFO[]
  TRAVEL_INFO TRAVEL_INFO[]
  ADDRESS     ADDRESS[]
  PASSPORT    PASSPORT[]
  FAMILY      FAMILY[]
  PRESS_WORK  PRESS_WORK[]
  PREV_WORK   PREV_WORK[]
  ADD_WORK    ADD_WORK[]
  SECURITY    SECURITY[]
}

model CLIENT_INFO {
  ID_CLIENT_INF BigInt @id @default(autoincrement())
  ID_APPLICATION BigInt

  PS_HOLD       String?
  PS_OCOUNTRY   String?
  PS_RESIDENT   String?
  PS_RCOUNTRY   String?
  PS_HOCCOUNTRY String?
  PS_PASSHOLD   String?
  PS_IDENTITY   String?
  PS_SECNUMBER  String?
  PS_TAXNUMBER  String?
  PS_QST1       String?
  PS_OSURN      String?
  PS_OGIVN      String?
  PS_TELCOD     String?
  PS_DCITY      String?
  PS_DSTATE     String?
  PS_MARITAL    String?
  PS_FULLNAME   String?

  APPLICATION APPLICATION @relation(fields: [ID_APPLICATION], references: [ID_APPLICATION])
}

model TRAVEL_INFO {
  ID_TRAVEL BigInt @id @default(autoincrement())
  ID_APPLICATION BigInt

  PTI_BEEN       String?
  PTI_DATE1      DateTime?
  PTI_LEN1       String?
  PTI_DATE2      DateTime?
  PTI_LEN2       String?
  PTI_DATE3      DateTime?
  PTI_LEN3       String?
  PTI_DATE4      DateTime?
  PTI_LEN4       String?
  PTI_DATE5      DateTime?
  PTI_LEN5       String?

  PTI_HOLDRIVER  String?
  PTI_LICENSE    String?
  PTI_SLICENSE   String?
  PTI_ISSUEDV    String?
  PTI_DATEISSUED DateTime?
  PTI_DATEXPIRED DateTime?
  PTI_REDNUMBER  String?
  PTI_SAMEVISA   String?
  PTI_SAMECNT    String?
  PTI_TENPRINTED String?
  PTI_LOST       String?

  PTI_QST1 String?
  PTI_RST1 String?
  PTI_QST2 String?
  PTI_RST2 String?
  PTI_QST3 String?
  PTI_RST3 String?
  PTI_QST4 String?
  PTI_RST4 String?
  PTI_QST5 String?
  PTI_RST5 String?

  APPLICATION APPLICATION @relation(fields: [ID_APPLICATION], references: [ID_APPLICATION])
}

model ADDRESS {
  ID_ADDRESS BigInt @id @default(autoincrement())
  ID_APPLICATION BigInt

  ADD_ADD1 String?
  ADD_ADD2 String?
  ADD_CITY String?
  ADD_STATE String?
  ADD_POSTAL String?
  ADD_COUNTRY String?
  ADD_MAILING String?
  ADD_SAMEADD String?

  ADD_MADD1 String?
  ADD_MADD2 String?
  ADD_MCITY String?
  ADD_MSTATE String?
  ADD_MPOSTAL String?
  ADD_MCOUNTRY String?

  ADD_PHONE1 String?
  ADD_PHONE2 String?
  ADD_WPHONE String?
  ADD_ADDPHONE String?
  ADD_PHONE3 String?

  ADD_MAIL1 String?
  ADD_ADDMAIL String?
  ADD_MAIL2 String?

  APPLICATION APPLICATION @relation(fields: [ID_APPLICATION], references: [ID_APPLICATION])
}

model PASSPORT {
  ID_PASSPORT BigInt @id @default(autoincrement())
  ID_APPLICATION BigInt

  PI_TYPE String?
  PI_NUMBER String?
