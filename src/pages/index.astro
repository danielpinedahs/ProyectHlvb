---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Formulario Clientes">
  <div class="container">
    <div class="left-panel">
      <div class="image-stack">
        <img src="../HOME.gif" alt="Imagen base" class="imagen-base" />
        <img src="../HLVB-LOGO-04.png" alt="Imagen superpuesta" class="imagen-superpuesta" />
      </div>
    </div>
    <div class="right-panel">
      <form id="loginForm">
        <input type="text" id="ps_surname" name="ps_surname" placeholder="SURNAMES (e.g., FERNANDEZ GARCIA)" required />
        <input type="text" id="ps_givnam" name="ps_givnam" placeholder="GIVEN NAMES(e.g., JUAN MIGUEL)" required />

        <select id="ps_sex" name="ps_sex" required>
          <option value="">-- SEX --</option>
          <option value="M">MALE</option>
          <option value="F">FEMALE</option>
          <option value="O">OTHER</option>
        </select>

        <input type="email" id="ps_email" name="ps_email" placeholder="EMAIL (e.g., contact@hlvb.com)" required />
        <label for="ps_dbirth">DATE OF BIRTH</label>
        <input type="date" id="ps_dbirth" name="ps_dbirth" required/>

        <button type="submit" class="boton-guardar">CONTINUE</button>
      </form>
    </div>
  </div>

<script>
  window.addEventListener("DOMContentLoaded", () => {
    const form = document.getElementById("loginForm");

    form?.addEventListener("submit", async (e) => {
      e.preventDefault();

      const formEl = e.currentTarget as HTMLFormElement;

      const payload = {
        ps_surname: (formEl.querySelector("#ps_surname") as HTMLInputElement).value,
        ps_givnam: (formEl.querySelector("#ps_givnam") as HTMLInputElement).value,
        ps_sex: (formEl.querySelector("#ps_sex") as HTMLSelectElement).value,
        ps_email: (formEl.querySelector("#ps_email") as HTMLInputElement).value,
        ps_dbirth: (formEl.querySelector("#ps_dbirth") as HTMLInputElement).value
      };

      const res = await fetch("/api/login-or-fetch", {
        method: "POST",
        headers: {
          "Content-Type": "application/json"
        },
        body: JSON.stringify(payload)
      });

      const data = await res.json();

      // cliente NO existe
      if (data.found === false) {
        const create = confirm("Usuario no existe. ¿Deseas crearlo?");
        if (!create) return;

        const createRes = await fetch("/api/create", {
          method: "POST",
          headers: {
            "Content-Type": "application/json"
          },
          body: JSON.stringify(payload)
        });

        const newClient = await createRes.json();

        localStorage.setItem("client", JSON.stringify(newClient));

        window.location.href =
          `/welcome?id=${newClient.client.id}`;

        return;
      }

      // cliente existe
      localStorage.setItem("client", JSON.stringify(data));

      window.location.href =
        `/welcome?id=${data.client.id}`;  
    });
  });
</script>

</BaseLayout>