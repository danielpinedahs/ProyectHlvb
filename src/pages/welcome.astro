---
export const prerender = false;

import { PrismaClient } from "@prisma/client";

import "../styles/styleHom.css";
import Family from "../components/family-info.astro";
import Passport from "../components/passport-info.astro";
import Address from "../components/address-info.astro";


const prisma = new PrismaClient();

const id = Astro.url.searchParams.get("id");

console.log("ID URL:", id);

const clientId = BigInt(id || "0");

const cliente = await prisma.cLIENTS.findUnique({
  where: {
    ID_CLIENT: clientId
  }
});

const aplicaciones = await prisma.aPPLICATION.findMany({
  where: {
    ID_CLIENT: clientId
  },
  orderBy: {
    ID_APPLICATION: "desc"
  }
});

console.log("CLIENTE:", cliente);

await prisma.$disconnect();
---
<script>
    const menu = document.getElementById("menu");
    const sidebar = document.getElementById("sidebar");
    const main = document.getElementById("main");

    menu?.addEventListener("click", () => {
        sidebar?.classList.toggle("menu-toggle");
        menu.classList.toggle("menu-toggle");
        main?.classList.toggle("menu-toggle");
    });

     document.querySelectorAll("#sidebar a").forEach(link => {
    link.addEventListener("click", (e) => {
      e.preventDefault();

      // Buscar el texto del <span> de este link
      const span = link.querySelector("span");
      if (!span) return; // seguridad

      // Crear el id esperado (ej: "PERSONAL INFO" -> "personalinfo")
      const target = span.innerText.toLowerCase().replace(/\s+/g, "");
      const section = document.getElementById(target);

     

      // Opcional: resaltar item activo
      document.querySelectorAll("#sidebar a").forEach(a => a.classList.remove("selected"));
      link.classList.add("selected");
    });
  });

  //

</script>

<html lang="es">
    <head>
        <meta charset="UTF-8" />
        <title>DS160 Form</title>
    </head>
    <header>
        <div class="left">
            <div class="menu-container">
                <div class="menu" id="menu">
                    <div></div>
                    <div></div>
                    <div></div>
                </div>
            </div>
            <div class="brand">
                <img src="../HLVBlogo.png" alt="icon-hlvb" class="logo" />
                <span class="name">FORM DS160 HLVB</span>
            </div>
        </div>
        <div class="right">
            <a href="/personal" class="icons-header">
                <img src="../personal.svg" alt="chat" />
            </a>
            <a href="#" class="icons-header">
                <img src="../personal.svg" alt="question" />
            </a>
            <a href="/" class="icons-header">
                <img src="../sign-out.svg" alt="notification" />
            </a>
            <img src="../darth-vader.svg" alt="img-user" class="user" />
        </div>
    </header>
    <body>
        
        <div class="sidebar" id="sidebar">
            <nav>
                <ul>
                    <li>
                        <a href="#" class="selected">
                            <img src="../personal.svg" alt="" />
                            <span>MY APPS</span>
                        </a>
                    </li>
                    <li>
                        <a href="#">
                            <img src="../address.svg" alt="" />
                            <span>OPTION 1</span>
                        </a>
                    </li>
                    <li>
                        <a href="#">
                            <img src="../passport.svg" alt="" />
                            <span>OPTION 2</span>
                        </a>
                    </li>
                    <li>
                        <a href="#">
                            <img src="../family.svg" alt="" />
                            <span>OPTION 3</span>
                        </a>
                    </li>
                </ul>
            </nav>
        </div>
        
        <main id="main">
            <section id="personalinfo" data-step="1" class="content active">

  <h1>
    WELCOME,
    {cliente?.PS_SURNAME}
    {" "}
    {cliente?.PS_GIVNAM}
  </h1>

  <br />

  {
    aplicaciones.length > 0 ? (

      <table border="1">
        <thead>
          <tr>
            <th>APP ID</th>
            <th>STATUS</th>
            <th>CREATED</th>
            <th>UPDATED</th>
          </tr>
        </thead>

        <tbody>
          {
            aplicaciones.map((app) => (
              <tr>
                <td>{app.ID_APPLICATION.toString()}</td>

                <td>{app.APP_STATUS}</td>

                <td>
                  {
                    app.APP_CREATED
                      ? new Date(app.APP_CREATED)
                          .toISOString()
                          .split("T")[0]
                      : ""
                  }
                </td>

                <td>
                  {
                    app.APP_UPDATED
                      ? new Date(app.APP_UPDATED)
                          .toISOString()
                          .split("T")[0]
                      : ""
                  }
                </td>
              </tr>
            ))
          }
        </tbody>
      </table>

    ) : (

      <p>THIS CLIENT HAS NO APPLICATIONS</p>

    )
  }

  <br />

  <button>
    + CREATE APPLICATION
  </button>

</section>

            <section id="addressinfo" data-step="3" class="content hidden">
                <Address />
            </section>

            <section id="passportinfo" data-step="4" class="content hidden">
                <Passport />
            </section>

            <section id="familyinfo" data-step="5" class="content hidden">
                <Family />
            </section>

             <!-- 🔔 Contenedor global de notificaciones -->

        </main>
        <div id="notification" class="hidden fixed bottom-5 right-5 bg-green-600 text-white px-4 py-2 rounded shadow-lg transition-all duration-500"
    >HOLA</div>

    </body>

</html>




