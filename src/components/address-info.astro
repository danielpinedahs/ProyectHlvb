---
import "../styles/styleform.css"
---
<h2>ADDRESS INFO</h2>  

<form id="miFormulario" action="#" method="post">
 <h3>Contact Information</h3>       
    
    <div class="form-row">
        <div class="form-field">
            <label for="streetAddress1">Street Address (Line 1)</label>
            <input type="text" id="streetAddress1" name="streetAddress1">
        </div>    
        <div class="form-field">
            <label for="streetAddress2">Street Address (Line 2)</label>
            <input type="text" id="streetAddress2" name="streetAddress2">
        </div>   
    </div>    
    <div class="form-row">
        <div class="form-field">
            <label for="city">City</label>
            <input type="text" id="city" name="city">
        </div>    
        <div class="form-field">
            <label for="stateProvince">State/Province</label>
            <input type="text" id="stateProvince" name="stateProvince">
        </div>   
    </div>    
    <div class="form-row">
        <div class="form-field">
            <label for="postalCode">Postal Zone/ZIP Code</label>
            <input type="text" id="postalCode" name="postalCode">
        </div>    
        <div class="form-field">
            <label for="countryRegion">Country/Region</label>
            <input type="text" id="countryRegion" name="countryRegion">
        </div>   
    </div>
<h2>Mailing Address</h2> 
    <div class="form-row">
        <div class="form-field">
            <label for="sameAsStreetAddress">Is your Mailing Address the same as your Street Address?</label>
            <input type="text" id="sameAsStreetAddress" name="sameAsStreetAddress">
        </div>    
        <div class="form-field">
            <label for="mailingStreetAddress1">Street Address (Line 1)</label>
            <input type="text" id="mailingStreetAddress1" name="mailingStreetAddress1">
        </div>   
    </div>    
    <div class="form-row">
        <div class="form-field">
            <label for="mailingStreetAddress2">Street Address (Line 2)</label>
            <input type="text" id="mailingStreetAddress2" name="mailingStreetAddress2">
        </div>    
        <div class="form-field">
            <label for="mailingCity">City</label>
            <input type="text" id="mailingCity" name="mailingCity">
        </div>   
    </div>    
    <div class="form-row">
        <div class="form-field">
            <label for="mailingStateProvince">State/Province</label>
            <input type="text" id="mailingStateProvince" name="mailingStateProvince">
        </div>    
        <div class="form-field">
            <label for="mailingPostalCode">Postal Zone/ZIP Code</label>
            <input type="text" id="mailingPostalCode" name="mailingPostalCode">
        </div>   
    </div>      
    <div class="form-row">
        <div class="form-field">
            <label for="mailingCountryRegion">Country/Region</label>
            <input type="text" id="mailingCountryRegion" name="mailingCountryRegion">
        </div>    
        <div class="form-field">
            
        </div>   
    </div> 
<h2>Phone and Email</h2>       
    <div class="form-row">
        <div class="form-field">
            <label for="primaryPhoneNumber">Primary Phone Number</label>
            <input type="text" id="primaryPhoneNumber" name="primaryPhoneNumber">
        </div>    
        <div class="form-field">
            <label for="secondaryPhoneNumber">Secondary Phone Number</label>
            <input type="text" id="secondaryPhoneNumber" name="secondaryPhoneNumber">
        </div>   
    </div>    
    <div class="form-row">
        <div class="form-field">
            <label for="workPhoneNumber">Work Phone Number</label>
            <input type="text" id="workPhoneNumber" name="workPhoneNumber">
        </div>    
        <div class="form-field">
            <label for="additionalPhoneUsed">Have you used any additional phone?</label>
            <input type="text" id="additionalPhoneUsed" name="additionalPhoneUsed">
        </div>   
    </div>    
    <div class="form-row">
        <div class="form-field">
            <label for="additionalPhoneNumbers">If so, please provide all additional phone</label>
            <input type="text" id="additionalPhoneNumbers" name="additionalPhoneNumbers">
        </div>    
        <div class="form-field">
            <label for="emailAddress">Email Address</label>
            <input type="text" id="emailAddress" name="emailAddress">
        </div>   
    </div>    
    <div class="form-row">
        <div class="form-field">
            <label for="additionalEmailUsed">Have you used any additional email?</label>
            <input type="text" id="additionalEmailUsed" name="additionalEmailUsed">
        </div>    
        <div class="form-field">
            <label for="additionalEmails">If so, please provide all additional email</label>
            <input type="text" id="additionalEmails" name="additionalEmails">
        </div>   
    </div>    
        <button type="submit">Save and Continue</button>
</form>
