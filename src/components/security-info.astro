---
import "../styles/styleform.css"
---
<h2>Security and Background Information</h2>
<form id="miFormulario" action="#" method="post">
        
        
    <div class="form-row">
        <div class="form-field">
           <label for="publicHealthSignificance">Do you have any communicable disease of public health significance?</label>
            <div class="radio-options" >
                <label><input type="radio" name="ps_resident" value="Y" > Yes</label>
                <label><input type="radio" name="ps_resident" value="N" > No</label>
            </div>
        </div>    
        <div class="form-field">
            <label for="explainPublicHealth">Explain</label>
            <textarea id="explainPublicHealth" name="explainPublicHealth" rows="3"></textarea>
        </div>   
    </div>
    <div class="form-row">
        <div class="form-field">
           <label for="mentalOrPhysicalDisorder">Have you ever had a mental or physical disorder that poses a threat to the safety of yourself or others?</label>
            <div class="radio-options" >
                <label><input type="radio" name="ps_resident" value="Y" > Yes</label>
                <label><input type="radio" name="ps_resident" value="N" > No</label>
            </div>
        </div>    
        <div class="form-field">
            <label for="explainDisorder">Explain</label>
            <textarea id="explainDisorder" name="explainDisorder" rows="3"></textarea>
        </div>   
    </div>
    <div class="form-row">
        <div class="form-field">
           <label for="drugAbuser">Are you or have you ever been a drug abuser or addict?</label>
            <div class="radio-options" >
                <label><input type="radio" name="ps_resident" value="Y" > Yes</label>
                <label><input type="radio" name="ps_resident" value="N" > No</label>
            </div>
        </div>    
        <div class="form-field">
            <label for="explainDrugAbuser">Explain</label>
            <textarea id="explainDrugAbuser" name="explainDrugAbuser" rows="3"></textarea>
        </div>   
    </div>
    <div class="form-row">
        <div class="form-field">
           <label for="convictedLaw">Have you ever been arrested or convicted for violating any law?</label>
            <div class="radio-options" >
                <label><input type="radio" name="ps_resident" value="Y" > Yes</label>
                <label><input type="radio" name="ps_resident" value="N" > No</label>
            </div>
        </div>    
        <div class="form-field">
            <label for="explainConvictedLaw">Explain</label>
            <textarea id="explainConvictedLaw" name="explainConvictedLaw" rows="3"></textarea>
        </div>   
    </div>     
    <div class="form-row">
        <div class="form-field">
           <label for="involveProstitution">Have you ever been involved in, or do you seek to come to the U.S. to engage in, prostitution or unlawful commercialized vice?</label>
            <div class="radio-options" >
                <label><input type="radio" name="ps_resident" value="Y" > Yes</label>
                <label><input type="radio" name="ps_resident" value="N" > No</label>
            </div>
        </div>    
        <div class="form-field">
            <label for="explainProstitution">Explain</label>
            <textarea id="explainProstitution" name="explainProstitution" rows="3"></textarea>
        </div>   
    </div>  
    <div class="form-row">
        <div class="form-field">
           <label for="commitCrime">Have you ever committed or conspired to commit a human trafficking crime?</label>
            <div class="radio-options" >
                <label><input type="radio" name="ps_resident" value="Y" > Yes</label>
                <label><input type="radio" name="ps_resident" value="N" > No</label>
            </div>
        </div>    
        <div class="form-field">
            <label for="explainCommitCrime">Explain</label>
            <textarea id="explainCommitCrime" name="explainCommitCrime" rows="3"></textarea>
        </div>   
    </div>  
    <div class="form-row">
        <div class="form-field">
           <label for="votedInUS">Have you ever voted in the United States?</label>
            <div class="radio-options" >
                <label><input type="radio" name="ps_resident" value="Y" > Yes</label>
                <label><input type="radio" name="ps_resident" value="N" > No</label>
            </div>
        </div>    
        <div class="form-field">
            <label for="explainVotedInUS">Explain</label>
            <textarea id="explainVotedInUS" name="explainVotedInUS" rows="3"></textarea>
        </div>   
    </div>  
    <div class="form-row">
        <div class="form-field">
           <label for="memberGang">Have you been a member of, or in any way associated with, a gang or criminal organization?</label>
            <div class="radio-options" >
                <label><input type="radio" name="ps_resident" value="Y" > Yes</label>
                <label><input type="radio" name="ps_resident" value="N" > No</label>
            </div>
        </div>    
        <div class="form-field">
            <label for="explainGang">Explain</label>
            <textarea id="explainGang" name="explainGang" rows="3"></textarea>
        </div>   
    </div>  
        <button type="submit">Save and Continue</button>
    </form>
